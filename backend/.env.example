# AcessoIA Backend - Environment Template
# Copie este arquivo para .env e preencha com valores reais.

# Server
PORT=3001
NODE_ENV=development

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://SEU-PROJETO.upstash.io
UPSTASH_REDIS_REST_TOKEN=SEU_UPSTASH_REDIS_REST_TOKEN

# Google Gemini
GEMINI_API_KEY=SUA_GEMINI_API_KEY

# ElevenLabs
ELEVENLABS_API_KEY=SUA_ELEVENLABS_API_KEY
ELEVENLABS_VOICE_ID=SUA_ELEVENLABS_VOICE_ID

# Email - Gmail SMTP (Usar App Password com 2FA)
# Gerar em: https://myaccount.google.com/apppasswords
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=aaaa_bbbb_cccc_dddd
