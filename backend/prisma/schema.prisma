generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   
  name      String?
  role      String   @default("user") 
  
  resetCode    String?
  resetExpires DateTime?

  loginAttempts LoginAttempt[]
  auditLogs     AuditLog[]
  chatHistories ChatHistory[]
  apiCalls      ApiCall[]
  calendarEvents CalendarEvent[]
  notifications  Notification[]
  notificationPreferences NotificationPreference?
  integrationKeys IntegrationKey[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 

  @@index([email])
  @@index([role])
}

model CalendarEvent {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  
  date      DateTime
  title     String
  description String? @db.Text
  color     String   
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
  @@index([date])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?  
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  email     String   
  success   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())
  
  @@index([email])
  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action    String   
  resource  String?  
  changes   Json?   
  status    String   @default("success") 
  errorMsg  String?
  
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resource])
}

model ChatHistory {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  sessionId String   
  question  String   @db.Text 
  answer    String   @db.Text 

  source    String   
  confidence Float  @default(0.0) 
  audioUrl  String?  
  
  embedding String? @db.Text 
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([source])
}

model ApiCall {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  endpoint  String   
  method    String   
  status    Int     

  duration  Int     

  requestBody  Json?     
  responseBody Json?     
  error        String?   
  
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([endpoint])
  @@index([method])
  @@index([status])
  @@index([createdAt])
}

model SystemConfig {
  id        String   @id @default("current")
  
  embeddingStrategy String @default("tfidf") 
  tfidfThreshold    Float  @default(0.75)
  geminiThreshold   Float  @default(0.85)

  ttsModel  String   @default("elevenlabs")
  
  audioStorage String @default("cloudinary")
  audioTtl  Int      @default(259200)

  maxAudioPerSession Int @default(100)
  maxRequestSizeMb   Int @default(10)

  modifiedBy String?
  version    Int      @default(1)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiUsage {
  id        String   @id @default(cuid())
  
  service   String   
  tokens    Int?     
  characters Int?   
  requests  Int      @default(1) 
  
  estimatedCost Float @default(0.0)
  
  createdAt DateTime @default(now())
  date      DateTime @default(now()) 
  
  @@index([service])
  @@index([date])
  @@unique([service, date], name: "service_date")
}

model Notification {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  
  type      String   
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
  @@index([read])
  @@index([createdAt])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  adminId   String   @unique
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  
  infrastructureErrors Boolean @default(true)
  performanceWarnings  Boolean @default(true)
  backupLogs           Boolean @default(true)
  weeklyCostReports    Boolean @default(false)
  
  updatedAt DateTime @updatedAt
}

model IntegrationKey {
  id           String   @id @default(cuid())
  adminId      String
  admin        User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  
  service      String  
  encryptedKey String   
  isActive     Boolean  @default(true)
  
  lastVerified DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([adminId, service])
}
